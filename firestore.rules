rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------
    // Helper functions
    // ----------------------------------------------------------------

    // 管理者判定
    // TODO: 本番では Firebase Custom Claims (request.auth.token.admin == true) への移行を推奨
    function isAdmin() {
      return request.auth != null
          && request.auth.uid == "A1QGME5vqTVVJTNXLhqZSm0gCX43";
    }

    // 謎を解く操作 —— 未解決の謎を初めて解くときだけ許可
    // solved: false → true への遷移のみ、かつ変更フィールドは4つに限定
    function isSolveUpdate(puzzleId) {
      let allowed = ['solved', 'solvedBy', 'solvedByUid', 'solvedAt'];
      return request.auth != null
          && request.appCheck != null
          && resource.data.solved == false
          && request.resource.data.solved == true
          && request.resource.data.solvedByUid == request.auth.uid
          && request.resource.data.solvedBy is string
          && request.resource.data.solvedBy.size() > 0
          && request.resource.data.solvedBy.size() <= 50
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed)
          // 回答の正当性は attempts サブコレクションへの書き込みで担保する
          && exists(/databases/$(database)/documents/puzzles/$(puzzleId)/attempts/$(request.auth.uid));
    }

    // 作成者による編集 —— タイトル・概要・場所のみ変更可能
    function isCreatorEdit() {
      let allowed = ['title', 'description', 'location'];
      return request.auth != null
          && request.appCheck != null
          && request.auth.uid == resource.data.creatorId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed)
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 30;
    }

    // ----------------------------------------------------------------
    // puzzles コレクション
    // ----------------------------------------------------------------
    match /puzzles/{puzzleId} {

      // 誰でも読み取り可（トップページ一覧・謎ページ・OGP生成）
      allow read: if true;

      // ログインユーザーのみ投稿可。creatorId は自分のUIDでなければならない
      allow create: if request.auth != null
          && request.appCheck != null
          && request.resource.data.creatorId == request.auth.uid
          && request.resource.data.keys().hasAll(['title', 'imageUrl', 'answerType', 'creatorId', 'creatorName', 'solved', 'createdAt'])
          && request.resource.data.keys().hasOnly(['title', 'description', 'location', 'imageUrl', 'answerType', 'answer', 'answers', 'hashedAnswers', 'creatorId', 'creatorName', 'solved', 'solvedBy', 'solvedByUid', 'solvedAt', 'createdAt'])
          && request.resource.data.solved == false
          // 型・サイズ検証
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 30
          && request.resource.data.imageUrl is string
          && request.resource.data.imageUrl.matches('https://firebasestorage\\.googleapis\\.com/.*')
          && request.resource.data.answerType in ['keyword', 'qrcode']
          && request.resource.data.creatorName is string
          && request.resource.data.creatorName.size() > 0
          && request.resource.data.creatorName.size() <= 50
          // description / location はオプションだが、存在する場合はサイズ制限
          && (!request.resource.data.keys().hasAny(['description']) || (request.resource.data.description is string && request.resource.data.description.size() <= 500))
          && (!request.resource.data.keys().hasAny(['location']) || (request.resource.data.location is string && request.resource.data.location.size() <= 30))
          // hashedAnswers はリスト形式で最大10個
          && (!request.resource.data.keys().hasAny(['hashedAnswers']) || (request.resource.data.hashedAnswers is list && request.resource.data.hashedAnswers.size() <= 10));

      // 更新は3パターンのみ許可
      allow update: if isSolveUpdate(puzzleId)    // ログインユーザーのみ（未解決→解決の1回のみ）
                 || isCreatorEdit()       // 作成者によるメタ情報編集
                 || isAdmin();           // 管理者は何でも可

      // 削除: 作成者 or 管理者
      allow delete: if (request.auth != null && request.appCheck != null && request.auth.uid == resource.data.creatorId) || isAdmin();

      // 平文解答を保存する secrets サブコレクション
      match /secrets/data {
        allow read: if request.auth != null
            && request.appCheck != null
            && get(/databases/$(database)/documents/puzzles/$(puzzleId)).data.creatorId == request.auth.uid;
        allow create: if request.auth != null
            && request.appCheck != null
            && get(/databases/$(database)/documents/puzzles/$(puzzleId)).data.creatorId == request.auth.uid
            && request.resource.data.keys().hasOnly(['answers'])
            && request.resource.data.answers is list
            && request.resource.data.answers.size() <= 10;
        // 更新・削除は明示的に禁止
        allow update, delete: if false;
      }

      // 回答検証用のサブコレクション
      match /attempts/{userId} {
        // App Check 必須、ログインユーザーかつ自分に対する保存
        // hashing.sha256 を使って回答をハッシュ化し、親の hashedAnswers に含まれるか検証
        allow create: if request.auth != null
            && request.appCheck != null
            && request.auth.uid == userId
            && request.resource.data.keys().hasOnly(['answer'])
            && request.resource.data.answer is string
            && request.resource.data.answer.size() <= 100
            && (
                hashing.sha256((puzzleId + request.resource.data.answer).utf8()).toHexString()
                in get(/databases/$(database)/documents/puzzles/$(puzzleId)).data.hashedAnswers
            );
        allow read, update, delete: if false; // クライアントからの読み取りや更新は不可
      }
    }

    // ----------------------------------------------------------------
    // users コレクション
    // ----------------------------------------------------------------
    match /users/{userId} {

      // 誰でも読み取り可（ユーザープロフィールページ）
      allow read: if true;

      // 自分自身のドキュメントのみ作成・更新可（ログイン時の自動 upsert / SNSリンク保存）
      allow create, update: if request.auth != null
          && request.appCheck != null
          && request.auth.uid == userId
          && request.resource.data.keys().hasOnly(['displayName', 'photoURL', 'lastLoginAt', 'socialLinks'])
          && request.resource.data.displayName is string
          && request.resource.data.displayName.size() > 0
          && request.resource.data.displayName.size() <= 50
          && (!request.resource.data.keys().hasAny(['photoURL']) || (request.resource.data.photoURL is string && request.resource.data.photoURL.size() <= 500))
          && (!request.resource.data.keys().hasAny(['socialLinks']) || (
              request.resource.data.socialLinks is map
              && request.resource.data.socialLinks.keys().hasOnly(['twitter', 'instagram', 'github'])
          ));

      // 削除: 管理者のみ
      allow delete: if isAdmin();
    }
  }
}
